# ============================================
# TRADING AI AGENT - PRODUCTION CONFIGURATION
# ============================================
# Copy this file to .env and fill in your credentials
# ============================================

# ============================================
# APPLICATION
# ============================================
APP_NAME=Trading AI Agent
APP_VERSION=2.0.0
DEBUG=false
HOST=0.0.0.0
PORT=3030

# ============================================
# DATABASE - NEON POSTGRESQL (FREE)
# ============================================
# 1. Go to https://neon.tech/
# 2. Sign up with GitHub
# 3. Create new project
# 4. Copy connection string below
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/trading_ai?sslmode=require

# For local development (SQLite):
# DATABASE_URL=sqlite:///./trading.db

# ============================================
# REDIS CACHE - UPSTASH (FREE)
# ============================================
# 1. Go to https://upstash.com/
# 2. Create Redis database
# 3. Copy URL below
REDIS_URL=redis://default:xxx@us1-xxx.redis.upstash.io:6379
REDIS_ENABLED=true

# For local development (no Redis):
# REDIS_ENABLED=false

# ============================================
# LLM - DEEPSEEK (FREE!) OR OPENAI
# ============================================
# DEEPSEEK IS FREE: 5 million tokens/month!
# 
# Setup:
# 1. Go to https://platform.deepseek.com/
# 2. Sign up with email
# 3. API Keys → Create new key
# 4. Copy key below

OPENAI_API_KEY=sk-your-deepseek-or-openai-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# For OpenAI instead:
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ============================================
# ANGEL ONE BROKER (OPTIONAL - FOR LIVE TRADING)
# ============================================
# Get these from: https://smartapi.angelbroking.com/
ANGEL_ONE_API_KEY=
ANGEL_ONE_API_SECRET=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# ============================================
# TELEGRAM ALERTS (OPTIONAL)
# ============================================
# 1. Message @BotFather → /newbot → Get token
# 2. Message @userinfobot → Get chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# RISK MANAGEMENT
# ============================================
MAX_RISK_PER_TRADE=1.0
MAX_DAILY_LOSS=3.0
MAX_WEEKLY_LOSS=6.0
MAX_DRAWDOWN=10.0
MAX_TRADES_PER_DAY=3
MAX_OPEN_POSITIONS=3
MIN_RISK_REWARD=1.5

# ============================================
# SMC ENGINE
# ============================================
SWING_STRENGTH=3
EQUAL_LEVEL_THRESHOLD=0.1
FVG_MIN_SIZE=0.1
OB_MIN_IMPULSE=0.5

# ============================================
# MARKET HOURS (IST)
# ============================================
MARKET_START=09:15
MARKET_END=15:30

# ============================================
# TRADING MODE
# ============================================
# Set to false ONLY when you have broker credentials
PAPER_TRADING=true

# ============================================
# DEPLOYMENT FLAGS
# ============================================
RENDER=false
RAILWAY=false
